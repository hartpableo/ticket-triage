{% extends 'dashboard/base.html.twig' %}

{% block title %}Team | {{ app_name }}{% endblock %}
{% block page_title %}Agency Team Roster{% endblock %}

{% block dashboard_content %}
    <div id="view-team" class="view-content active-view">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0 text-dark">Agency Team Members (Support Agents)</h5>
                        <button class="btn btn-outline-primary btn-sm" onclick="showAddAgentModal()">
                            <i class="bi bi-envelope-plus me-1"></i> Invite Team Member
                        </button>
                    </div>
                    <div class="list-group list-group-flush mb-3" id="agents-settings-list">
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm mb-4">
                    <h5 class="fw-bold mb-3 text-dark">Roster Analytics</h5>
                    <div class="p-3 bg-light rounded-3 mb-3">
                        <div class="text-muted stats-roster-label">Active Staff Members</div>
                        <h2 class="fw-bold mb-0 mt-1" id="team-stat-active">{{ invites_data.active }}</h2>
                    </div>
                    <div class="p-3 bg-light rounded-3">
                        <div class="text-muted stats-roster-label">Pending Invitations</div>
                        <h2 class="fw-bold mb-0 mt-1" id="team-stat-pending">{{ invites_data.pending }}</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Add agent modal #}
    <div class="modal fade" id="addAgentModal" tabindex="-1" aria-labelledby="addAgentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addAgentModalLabel">Invite New Support Agent</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(invite_form) }}
                    {{ form_errors(invite_form) }}
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="agent-email-input" class="form-label fw-semibold text-dark">Team Member Email Address</label>
                            {{ form_widget(invite_form.email, { id: 'agent-email-input' }) }}
                            {{ form_errors(invite_form.email) }}
                        </div>
                        <div class="mb-3">
                            <label for="agent-role-input" class="form-label fw-semibold text-dark">Access Role / Permission Level</label>
                            {{ form_widget(invite_form.role, { id: 'agent-role-input' }) }}
                            {{ form_errors(invite_form.role) }}
                            <div class="form-text">Admins can adjust dashboard configurations, manage integrations, and invite other members. Regular members have access only to handle tickets.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        {{ form_widget(invite_form.submit) }}
                    </div>
                {{ form_end(invite_form) }}
            </div>
        </div>
    </div>
{% endblock %}
