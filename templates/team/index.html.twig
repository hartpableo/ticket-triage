{% extends 'dashboard/base.html.twig' %}

{% block title %}Team | {{ app_name }}{% endblock %}
{% block page_title %}Agency Team Roster{% endblock %}

{% block javascripts %}
    {{ importmap('dashboard.team') }}
{% endblock %}

{% block dashboard_content %}
    <div id="view-team" class="view-content active-view">
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold mb-0 text-dark">Agency Team Members</h5>
                        <button class="btn btn-outline-primary btn-sm" onclick="showAddAgentModal()">
                            <i class="bi bi-envelope-plus me-1"></i> Invite Team Member
                        </button>
                    </div>
                    <div class="list-group list-group-flush mb-3" id="agents-list">
                        {% for member in members %}
                            <div
                                class="list-group-item d-flex align-items-center justify-content-between py-3 px-0 border-0 border-bottom bg-transparent">
                                <div class="d-flex align-items-center">
                                    {% if member.photo is empty %}
                                        {% set initials = '' %}
                                        {% set parts = member.name|split(' ') %}
                                        {% if parts|length > 1 %}
                                            {% set initials = (parts[0]|slice(0, 1) ~ parts[parts|length - 1]|slice(0, 1))|upper %}
                                        {% else %}
                                            {% set initials = member.name|slice(0, 2)|upper %}
                                        {% endif %}
                                        <div
                                            class="avatar bg-primary text-white me-3 text-uppercase d-flex align-items-center justify-content-center fw-semibold rounded-circle shadow-sm"
                                            style="width: 2.5rem; height: 2.5rem; font-size: 0.95rem;">
                                            {{ initials }}
                                        </div>
                                    {% else %}
                                        <div
                                            class="avatar bg-primary text-white me-3 text-uppercase d-flex align-items-center justify-content-center fw-semibold rounded-circle shadow-sm"
                                            style="width: 2.5rem; height: 2.5rem; font-size: 0.95rem;background-image: url('{{ asset('uploads/profile_photos/' ~ member.photo) }}'); background-size: cover; background-position: center; color: transparent; text-shadow: none;"
                                        >
                                        </div>
                                    {% endif %}
                                    <div>
                                        <div class="d-flex align-items-center gap-2 flex-wrap">
                                            <h6 class="fw-bold mb-0 text-dark">{{ member.name }}</h6>
                                            {% if 'ROLE_ADMIN' in member.roles %}
                                                <span
                                                    class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill small-badge px-2 py-0.5">Administrator</span>
                                            {% else %}
                                                <span
                                                    class="badge bg-success-subtle text-success border border-success-subtle rounded-pill small-badge px-2 py-0.5">Support Agent</span>
                                            {% endif %}
                                        </div>
                                        <div class="text-muted small mt-1">
                                        <span class="d-inline-flex align-items-center me-3">
                                            <i class="bi bi-envelope me-1.5 text-secondary"></i> &nbsp; {{ member.email }}
                                        </span>
                                            <span class="d-inline-flex align-items-center">
                                            <i class="bi bi-person-badge me-1.5 text-secondary"></i> &nbsp; {{ member.title }}
                                        </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <div class="dropdown">
                                        <button class="btn btn-link text-muted p-0 border-0 bg-transparent"
                                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            <i class="bi bi-three-dots-vertical fs-5"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-light-subtle">
                                            <li><a class="dropdown-item" href="#"><i
                                                        class="bi bi-shield-lock me-2 text-muted"></i> Change Role</a>
                                            </li>
                                            <li>
                                                <hr class="dropdown-divider">
                                            </li>
                                            <li>
                                                <button type="button" class="dropdown-item text-danger js-remove-agent" onclick="removeAgent({{ member.id }}, '{{ member.name }}')">
                                                    <i class="bi bi-trash me-2"></i> Remove Agent
                                                </button>
                                            </li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm mb-4">
                    <h5 class="fw-bold mb-3 text-dark">Roster Analytics</h5>
                    <div class="p-3 bg-light rounded-3 mb-3">
                        <div class="text-muted stats-roster-label">Active Staff Members</div>
                        <h2 class="fw-bold mb-0 mt-1" id="team-stat-active">{{ invites_data.active }}</h2>
                    </div>
                    <div class="p-3 bg-light rounded-3">
                        <div class="text-muted stats-roster-label">Pending Invitations</div>
                        <h2 class="fw-bold mb-0 mt-1" id="team-stat-pending">{{ invites_data.pending }}</h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Add agent modal #}
    <div class="modal fade" id="addAgentModal" tabindex="-1" aria-labelledby="addAgentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addAgentModalLabel">Invite New Support Agent</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(invite_form) }}
                {{ form_errors(invite_form) }}
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="agent-email-input" class="form-label fw-semibold text-dark">Team Member Email
                            Address</label>
                        {{ form_widget(invite_form.email, { id: 'agent-email-input' }) }}
                        {{ form_errors(invite_form.email) }}
                    </div>
                    <div class="mb-3">
                        <label for="agent-role-input" class="form-label fw-semibold text-dark">Access Role / Permission
                            Level</label>
                        {{ form_widget(invite_form.role, { id: 'agent-role-input' }) }}
                        {{ form_errors(invite_form.role) }}
                        <div class="form-text">Admins can adjust dashboard configurations, manage integrations, and
                            invite other members. Regular members have access only to handle tickets.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                    {{ form_widget(invite_form.submit) }}
                </div>
                {{ form_end(invite_form) }}
            </div>
        </div>
    </div>
{% endblock %}
