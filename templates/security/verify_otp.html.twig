{% extends 'base.html.twig' %}

{% block title %}Verify Code - {{ app_name }}{% endblock %}

{% block body %}
<div class="d-flex flex-column min-vh-100 align-items-center justify-content-center px-3 py-5 bg-dark-subtle">
    <!-- Brand Logo and Name -->
    <div class="text-center mb-4">
        <a href="{{ path('app_home') }}" class="d-inline-flex align-items-center text-decoration-none fw-bold text-body fs-3">
            <i class="bi bi-shield-check text-primary me-2 fs-2" aria-hidden="true"></i>
            <span>{{ app_name }}</span>
        </a>
    </div>

    <!-- Centered Card -->
    <div class="card shadow-lg border-secondary-subtle rounded-4 p-4 p-sm-5" style="width: 100%; max-width: 440px;">
        <div class="mb-4 text-center">
            <span class="badge bg-warning-subtle text-warning border border-warning-subtle py-2 px-3 rounded-pill fs-7 fw-semibold">
                <i class="bi bi-shield-lock-fill me-1"></i> Two-Factor Check
            </span>
        </div>

        <h1 class="h3 fw-bold mb-2 text-center">Enter verification code</h1>
        <p class="text-center text-body-secondary small mb-4">We sent a 6-digit verification code to <strong>{{ email }}</strong>.</p>
        
        {# Display Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' or label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} d-flex align-items-center gap-2 mb-4" role="alert">
                    {% if label == 'error' or label == 'danger' %}
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    {% elseif label == 'success' %}
                        <i class="bi bi-check-circle-fill fs-5"></i>
                    {% else %}
                        <i class="bi bi-info-circle-fill fs-5"></i>
                    {% endif %}
                    <div class="small">{{ message }}</div>
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post" action="{{ path('app_login_verify') }}">
            <div class="mb-4">
                <label for="otp" class="form-label fw-medium text-body-secondary small text-center w-100">6-Digit Code</label>
                <input type="text" name="otp" id="otp" class="form-control border-secondary-subtle py-3 text-center fs-3 tracking-widest fw-bold" placeholder="000000" maxlength="6" pattern="[0-9]{6}" required autofocus autocomplete="one-time-code">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate_otp') }}">

            <button class="btn btn-success w-100 py-2.5 fw-semibold fs-6 d-flex align-items-center justify-content-center gap-2" type="submit">
                <span>Verify & Authenticate</span>
                <i class="bi bi-check2-all"></i>
            </button>
        </form>
        
        <div class="mt-4 text-center">
            <a href="{{ path('app_login') }}" class="text-secondary text-decoration-none fw-medium small"><i class="bi bi-arrow-left me-1"></i> Back to login</a>
        </div>
    </div>
</div>

<style>
.tracking-widest {
    letter-spacing: 0.25em;
}
#otp::placeholder {
    letter-spacing: normal;
}
</style>
{% endblock %}
