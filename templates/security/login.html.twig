{% extends 'base.html.twig' %}

{% block title %}Log in - {{ app_name }}{% endblock %}

{% block body %}
<div class="d-flex flex-column min-vh-100 align-items-center justify-content-center px-3 py-5 bg-dark-subtle">
    <!-- Brand Logo and Name -->
    <div class="text-center mb-4">
        <a href="{{ path('app_home') }}" class="d-inline-flex align-items-center text-decoration-none fw-bold text-body fs-3">
            <i class="bi bi-shield-check text-primary me-2 fs-2" aria-hidden="true"></i>
            <span>{{ app_name }}</span>
        </a>
    </div>

    <!-- Centered Card -->
    <div class="card shadow-lg border-secondary-subtle rounded-4 p-4 p-sm-5" style="width: 100%; max-width: 440px;">
        <h1 class="h3 fw-bold mb-2 text-center">Sign In</h1>
        <p class="text-center text-body-secondary small mb-4">Enter your email and we'll send a one-time passcode (OTP) to your inbox.</p>

        {# Display Authentication Error #}
        {% if error %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" role="alert">
                <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                <div class="small">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            </div>
        {% endif %}

        {# Display Flash Messages #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label == 'error' or label == 'danger' ? 'danger' : (label == 'success' ? 'success' : 'info') }} d-flex align-items-center gap-2 mb-4" role="alert">
                    {% if label == 'error' or label == 'danger' %}
                        <i class="bi bi-exclamation-triangle-fill fs-5"></i>
                    {% elseif label == 'success' %}
                        <i class="bi bi-check-circle-fill fs-5"></i>
                    {% else %}
                        <i class="bi bi-info-circle-fill fs-5"></i>
                    {% endif %}
                    <div class="small">{{ message }}</div>
                </div>
            {% endfor %}
        {% endfor %}

        <form method="post">
            <div class="mb-4">
                <label for="email" class="form-label fw-medium text-body-secondary small">Work Email</label>
                <div class="input-group">
                    <span class="input-group-text bg-body border-secondary-subtle"><i class="bi bi-envelope text-muted"></i></span>
                    <input type="email" name="email" id="email" class="form-control border-secondary-subtle py-2.5" placeholder="alex@agency.com" required autofocus autocomplete="email">
                </div>
            </div>

            <button class="btn btn-primary w-100 py-2.5 fw-semibold fs-6 d-flex align-items-center justify-content-center gap-2" type="submit">
                <span>Send Verification Code</span>
                <i class="bi bi-arrow-right"></i>
            </button>
        </form>

{#        <div class="mt-4 text-center">#}
{#            <span class="text-body-secondary small">Don't have an account? </span>#}
{#            <a href="{{ path('app_register') }}" class="text-primary text-decoration-none fw-semibold small">Sign up now &rarr;</a>#}
{#        </div>#}
    </div>
</div>
{% endblock %}
