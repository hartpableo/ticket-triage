{% extends 'base.html.twig' %}

{% block html_theme %}light{% endblock %}

{#{% block title %}Dashboard | {{ app_name }}{% endblock %}#}

{% block javascripts %}
    <script>
        window.userProfile = {
            name: "{{ app.user.name|default('Member')|escape('js') }}",
            role: "{{ app.user.title|default('Member')|escape('js') }}",
            email: "{{ app.user.email|escape('js') }}",
        };
    </script>
    {{ importmap('dashboard') }}
{% endblock %}

{% block body %}
    {% set initials = '' %}
    {% if app.user and app.user.name %}
        {% set parts = app.user.name|split(' ') %}
        {% if parts|length > 1 %}
            {% set initials = (parts[0]|slice(0, 1) ~ parts[parts|length - 1]|slice(0, 1))|upper %}
        {% else %}
            {% set initials = app.user.name|slice(0, 2)|upper %}
        {% endif %}
    {% else %}
        {% set initials = 'GU' %}
    {% endif %}
    <div id="main-dashboard-layout" class="d-flex" style="min-height: 100dvh;">
        <!-- Sidebar -->
        <aside class="sidebar d-none d-lg-flex flex-column text-white">
            <div class="sidebar-logo d-flex align-items-center">
                <i class="bi bi-shield-check text-primary me-2 fs-4"></i>
                <span>{{ app_name }}</span>
                <span class="badge bg-secondary ms-2 small-badge">Admin</span>
            </div>

            {% include 'admin-menu.html.twig' with {menu: admin_menu} only %}

            <!-- Sidebar Profile with Logout -->
            <div class="p-3 border-top border-secondary border-opacity-25 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <div class="avatar bg-primary text-white me-2 text-uppercase sidebar-avatar" id="sidebar-avatar-initials"
                         {% if app.user.photo %}style="background-image: url('{{ asset('uploads/profile_photos/' ~ app.user.photo) }}'); background-size: cover; background-position: center; color: transparent; text-shadow: none;"{% endif %}>
                        {% if not app.user.photo %}{{ initials }}{% endif %}
                    </div>
                    <div>
                        <div class="fw-semibold text-white sidebar-display-name" id="sidebar-display-name">{{ app.user.name }}</div>
                        <div class="sidebar-display-title" id="sidebar-display-title">{{ app.user.title }}</div>
                    </div>
                </div>
                <button class="btn btn-outline-light btn-sm border-0 p-1" onclick="logout()" title="Logout">
                    <i class="bi bi-box-arrow-right fs-5 text-danger"></i>
                </button>
            </div>
        </aside>

        <!-- Main Content Area -->
        <div class="flex-grow-1 d-flex flex-column" style="min-width: 0;">

            <!-- Topbar Header -->
            <header class="topbar d-flex align-items-center justify-content-between px-4">
                <div class="d-flex align-items-center">
                    <button class="btn btn-outline-secondary btn-sm d-lg-none me-3" type="button" data-bs-toggle="collapse" data-bs-target="#mobileSidebar" aria-expanded="false" aria-controls="mobileSidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <h4 class="mb-0 fw-semibold text-dark fs-5" id="page-title">
                        {% block page_title %}{% endblock %}
                    </h4>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <div class="border-start ps-3 d-lg-none">
                        <div class="avatar bg-primary text-white text-uppercase" id="mobile-avatar-initials"
                             {% if app.user.photo %}style="background-image: url('{{ asset('uploads/profile_photos/' ~ app.user.photo) }}'); background-size: cover; background-position: center; color: transparent; text-shadow: none;"{% endif %}>
                            {% if not app.user.photo %}{{ initials }}{% endif %}
                        </div>
                    </div>
                </div>
            </header>

            <!-- Mobile Sidebar Collapse -->
            <div class="collapse d-lg-none bg-dark text-white border-bottom" id="mobileSidebar">
                <div class="p-3">
                    <div class="list-group list-group-flush">
                        <a href="{{ path('app_tickets') }}" class="list-group-item list-group-item-action bg-dark text-white border-0 py-2" onclick="bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-ticket-perforated me-2"></i> Tickets
                        </a>
                        <a href="{{ path('app_analytics') }}" class="list-group-item list-group-item-action bg-dark text-white border-0 py-2" onclick="bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-bar-chart-line me-2"></i> Analytics
                        </a>
                        <a href="{{ path('app_clients') }}" class="list-group-item list-group-item-action bg-dark text-white border-0 py-2" onclick="bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-building me-2"></i> Clients
                        </a>
                        <a href="{{ path('app_team') }}" class="list-group-item list-group-item-action bg-dark text-white border-0 py-2" onclick="bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-people me-2"></i> Team
                        </a>
                        <a href="{{ path('app_settings') }}" class="list-group-item list-group-item-action bg-dark text-white border-0 py-2" onclick="bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-gear me-2"></i> Settings
                        </a>
                        <a href="#" class="list-group-item list-group-item-action bg-dark text-danger border-0 py-2" onclick="logout(); bootstrap.Collapse.getInstance(document.getElementById('mobileSidebar')).hide();">
                            <i class="bi bi-box-arrow-right me-2"></i> Logout
                        </a>
                    </div>
                </div>
            </div>

            <!-- Scrollable content view wrapper -->
            <div class="flex-grow-1 overflow-auto p-4">
                {% block dashboard_content %}{% endblock %}
            </div>
        </div>
    </div>

    <!-- ==============================================
         LOGOUT SCREEN MOCKUP
         ============================================== -->
    <div id="login-screen" class="d-none min-vh-100 bg-light align-items-center justify-content-center w-100">
        <div class="card border border-light-subtle rounded-3 p-4 shadow bg-white login-card">
            <div class="text-center mb-4">
                <i class="bi bi-shield-check text-primary fs-1"></i>
                <h3 class="fw-bold mt-2 text-dark">Ticket Triage</h3>
                <p class="text-muted small">Sign in to your agency portal</p>
            </div>

            <form onsubmit="login(event)">
                <div class="mb-3">
                    <label for="login-email" class="form-label fw-semibold text-dark">Email address</label>
                    <input type="email" class="form-control bg-light" id="login-email" value="alex@agency.com" autocomplete="username" disabled>
                </div>
                <div class="mb-3">
                    <label for="login-password" class="form-label fw-semibold text-dark">Password</label>
                    <input type="password" class="form-control" id="login-password" value="••••••••" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn btn-primary w-100 py-2 mt-2">Sign In</button>
            </form>
        </div>
    </div>

    <!-- ==============================================
         MODAL: CREATE NEW TICKET
         ============================================= -->
    <div class="modal fade" id="newTicketModal" tabindex="-1" aria-labelledby="newTicketModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="newTicketModalLabel">Submit Support Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="new-ticket-form" onsubmit="createNewTicket(event)">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="new-title" class="form-label fw-semibold">Subject / Issue Title</label>
                            <input type="text" class="form-control" id="new-title" required placeholder="e.g. SSL Certificate Expired">
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="new-client" class="form-label fw-semibold">Client Site</label>
                                <select class="form-select" id="new-client" required>
                                    <option value="">Select client...</option>
                                    <option value="Aura Cosmetics">Aura Cosmetics</option>
                                    <option value="Vertex SaaS">Vertex SaaS</option>
                                    <option value="Greenfield Real Estate">Greenfield Real Estate</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="new-category" class="form-label fw-semibold">Category</label>
                                <select class="form-select" id="new-category" required>
                                    <option value="Bug">Bug Report</option>
                                    <option value="Feature Request">Feature Request</option>
                                    <option value="Task">General Task</option>
                                    <option value="Question">Question / Help</option>
                                </select>
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="new-priority" class="form-label fw-semibold">Priority</label>
                                <select class="form-select" id="new-priority" required>
                                    <option value="Low">Low</option>
                                    <option value="Medium" selected>Medium</option>
                                    <option value="High">High</option>
                                    <option value="Critical">Critical</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="new-assignee" class="form-label fw-semibold">Assign Agent</label>
                                <select class="form-select" id="new-assignee">
                                    <!-- Loaded from JS -->
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="new-description" class="form-label fw-semibold">Description / Error Details</label>
                            <textarea class="form-control" id="new-description" rows="4" required placeholder="Describe the problem, steps to reproduce, or requested feature details..."></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Ticket</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ==============================================
         MODAL: ADD CLIENT
         ============================================= -->
    <div class="modal fade" id="addClientModal" tabindex="-1" aria-labelledby="addClientModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addClientModalLabel">Register New Client Website</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="new-client-form" onsubmit="createNewClient(event)">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="client-name-input" class="form-label fw-semibold">Client / Company Name</label>
                            <input type="text" class="form-control" id="client-name-input" required placeholder="e.g. Acme Corp">
                        </div>

                        <div class="mb-3">
                            <label for="client-domain-input" class="form-label fw-semibold">Allowed Domain (for CORS widget security)</label>
                            <div class="input-group">
                                <span class="input-group-text">https://</span>
                                <input type="text" class="form-control" id="client-domain-input" required placeholder="acmecorp.com">
                            </div>
                            <div class="form-text">The widget will only process requests sent from this domain.</div>
                        </div>

                        <div class="mb-3">
                            <label for="client-assignee-input" class="form-label fw-semibold">Assign Agent / Team Member</label>
                            <select class="form-select" id="client-assignee-input">
                                <!-- Loaded dynamically from JS -->
                            </select>
                            <div class="form-text">Select the primary agent responsible for managing this client.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Register Client</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ==============================================
         MODAL: ADD AGENT (INVITE EMAIL & ROLE SELECTION)
         ============================================= -->
    <div class="modal fade" id="addAgentModal" tabindex="-1" aria-labelledby="addAgentModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="addAgentModalLabel">Invite New Support Agent</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form id="new-agent-form" onsubmit="createNewAgent(event)">
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="agent-email-input" class="form-label fw-semibold text-dark">Team Member Email Address</label>
                            <input type="email" class="form-control" id="agent-email-input" required placeholder="e.g. colleague@agency.com">
                        </div>
                        <div class="mb-3">
                            <label for="agent-role-input" class="form-label fw-semibold text-dark">Access Role / Permission Level</label>
                            <select class="form-select" id="agent-role-input" required>
                                <option value="Regular Member" selected>Regular Member</option>
                                <option value="Admin">Admin</option>
                            </select>
                            <div class="form-text">Admins can adjust dashboard configurations, manage integrations, and invite other members. Regular members have access only to handle tickets.</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Send Invitation</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- ==============================================
         MODAL: WIDGET EMBED CODE & INSTRUCTIONS
         ============================================= -->
    <div class="modal fade" id="widgetEmbedModal" tabindex="-1" aria-labelledby="widgetEmbedModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="widgetEmbedModalLabel">Widget Integration Script</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-4">
                        <p class="text-muted">Give your clients a seamless way to submit and track support tickets directly inside their own website admin dashboards or control panels without logging out.</p>
                        <h6 class="fw-semibold mt-3">How it works:</h6>
                        <ol class="text-muted ps-3 small lh-lg">
                            <li>Copy the tailored integration script snippet below.</li>
                            <li>Paste it right before the closing <code>&lt;/body&gt;</code> tag on the client's internal site.</li>
                            <li>A feedback widget button will appear in the bottom-right corner automatically, authenticated via security hash.</li>
                        </ol>
                    </div>

                    <div>
                        <h6 class="fw-semibold mb-2" id="widget-modal-client-title">Embed Snippet:</h6>
                        <div class="code-container">
                            <button class="code-copy-btn" id="copy-btn" onclick="copyWidgetSnippet()"><i class="bi bi-copy me-1"></i> Copy</button>
                            <pre class="mb-0" id="widget-code-text"></pre>
                        </div>
                        <div class="form-text text-muted mt-2">
                            <i class="bi bi-info-circle me-1"></i> Never share your data-client-id key in public git repositories.
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </div>
    </div>

    {% include 'toast.html.twig' only %}
{% endblock %}
