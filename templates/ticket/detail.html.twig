{% extends 'dashboard/base.html.twig' %}

{% block javascripts %}
    {{ importmap('dashboard.tickets.single') }}
{% endblock %}

{% block page_title %}
    <span class="text-muted fw-normal">Tickets Queue</span>
    <span class="text-secondary mx-2">/</span>
    <span class="text-dark">{{ ticket.code }}</span>
{% endblock %}

{% block dashboard_content %}
    <div id="view-ticket-detail" class="view-content active-view">
        <div class="mb-4">
            <a href="{{ path('app_tickets') }}" class="btn btn-light btn-sm border">
                <i class="bi bi-arrow-left me-1"></i> Back to Queue
            </a>
        </div>

        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm mb-4">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
                        <h3 class="fw-bold mb-0 text-dark" id="detail-ticket-title">{{ ticket.title }}</h3>
                        <span class="badge bg-light text-secondary border px-3 py-2"
                              id="detail-ticket-id">{{ ticket.code }}</span>
                    </div>

                    <div class="mb-2">
                        <h6 class="fw-semibold text-muted text-uppercase small mb-2">Original Request Description</h6>
                        <div class="detail-description-box" id="detail-description">
                            {{- ticket.description|raw -}}
                        </div>
                        <div id="detail-description-attachments" class="d-flex flex-wrap gap-2"></div>
                    </div>
                </div>

                <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm">
                    <h5 class="fw-bold text-dark mb-4">Activity & Discussion</h5>
                    <div class="timeline mb-4" id="detail-timeline">
                        {% if comments is not empty %}
                            {% for comment in comments %}
                                <div class="timeline-item">
                                    <div class="timeline-badge{% if comment.type.value == 'system' %} system{% elseif comment.type.value == 'internal' %} internal{% endif %}"></div>
                                    <div class="d-flex align-items-start gap-3">
                                        {% if comment.author %}
                                            <div class="avatar bg-primary text-white text-uppercase flex-shrink-0"
                                                 {% if comment.author.photo %}style="background-image: url('{{ asset('uploads/profile_photos/' ~ comment.author.photo) }}'); background-size: cover; background-position: center; color: transparent; text-shadow: none;"{% endif %}>
                                                {% if not comment.author.photo %}
                                                    {% set name_parts = comment.author.name|split(' ') %}
                                                    {% if name_parts|length > 1 %}
                                                        {{ (name_parts[0]|slice(0, 1) ~ name_parts[name_parts|length - 1]|slice(0, 1))|upper }}
                                                    {% else %}
                                                        {{ comment.author.name|slice(0, 2)|upper }}
                                                    {% endif %}
                                                {% endif %}
                                            </div>
                                        {% else %}
                                            <div class="avatar bg-secondary text-white flex-shrink-0 d-flex align-items-center justify-content-center">
                                                <i class="bi bi-cpu"></i>
                                            </div>
                                        {% endif %}
                                        <div class="flex-grow-1">
                                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
                                                <div class="d-flex align-items-center gap-2">
                                                    <span class="fw-bold text-dark">
                                                        {% if comment.author %}
                                                            {{ comment.author.name }}
                                                        {% else %}
                                                            System
                                                        {% endif %}
                                                    </span>
                                                    {% if comment.author and app.user and comment.author.id == app.user.id %}
                                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1" style="font-size: 0.7rem;">You</span>
                                                    {% endif %}
                                                    {% if comment.type.value == 'internal' %}
                                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1" style="font-size: 0.7rem;">Internal Note</span>
                                                    {% endif %}
                                                </div>
                                                <small class="text-muted">{{ comment.createdAt|date('M d, Y \\a\\t H:i') }}</small>
                                            </div>
                                            <div class="comment-content text-secondary small">
                                                {{ comment.content|nl2br|raw }}
                                            </div>

                                            {% if comment.attachments is not empty %}
                                                <div class="d-flex flex-wrap gap-2 mt-2">
                                                    {% for attachment in comment.attachments %}
                                                        {% set file_ext = attachment.fileName|split('.')|last|lower %}
                                                        {% if file_ext in ['jpg', 'jpeg', 'png', 'gif', 'webp'] %}
                                                            <a href="{{ asset('uploads/attachments/' ~ attachment.fileName) }}" target="_blank" class="d-inline-block border rounded overflow-hidden" style="max-width: 150px; max-height: 150px;">
                                                                <img src="{{ asset('uploads/attachments/' ~ attachment.fileName) }}" class="img-fluid" alt="{{ attachment.fileName }}" style="object-fit: cover; width: 100%; height: 100%;">
                                                            </a>
                                                        {% else %}
                                                            <a href="{{ asset('uploads/attachments/' ~ attachment.fileName) }}" target="_blank" class="btn btn-sm btn-outline-secondary d-inline-flex align-items-center gap-1">
                                                                <i class="bi bi-file-earmark-arrow-down"></i>
                                                                {{ attachment.fileName }}
                                                            </a>
                                                        {% endif %}
                                                    {% endfor %}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div class="text-center py-4">
                                <div class="text-muted mb-2">
                                    <i class="bi bi-chat-left-text fs-2"></i>
                                </div>
                                <h6 class="fw-bold text-secondary">No activity yet</h6>
                                <p class="text-muted small mb-0">Be the first to post a response or check back later.</p>
                            </div>
                        {% endif %}
                    </div>

                    <hr class="my-4 border-light-subtle">

                    {{ form_start(comment_form) }}
                    {{ form_errors(comment_form) }}
                    <h6 class="fw-bold text-dark mb-2">Post a Response</h6>
                    <div class="mb-3">
                        {{ form_widget(comment_form.content, { id: 'comment-content' }) }}
                        {{ form_errors(comment_form.content) }}
                    </div>
                    <div class="mb-3 border rounded-3 p-3 bg-light">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 mb-2">
                            <div class="d-flex align-items-center gap-2">
                                <button class="btn btn-outline-secondary btn-sm" type="button"
                                        onclick="handleMediaAttachment('image')">
                                    <i class="bi bi-image me-1"></i> Attach Screenshot
                                </button>
                                <button class="btn btn-outline-secondary btn-sm" type="button"
                                        onclick="handleMediaAttachment('video')">
                                    <i class="bi bi-play-btn me-1"></i> Attach Recording
                                </button>
                            </div>
                            <button class="btn btn-link btn-sm text-danger p-0 d-none clear-attachments-link"
                                    id="clear-attachments-btn" type="button" onclick="clearAttachments()">
                                <i class="bi bi-trash3 me-1"></i> Clear all
                            </button>
                        </div>
                        <div id="attachment-preview-container" class="d-flex flex-wrap gap-2 mt-2"></div>
                    </div>

                    {{ form_widget(comment_form.attachments) }}

                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                        {{ form_widget(comment_form.type, { id: 'is-internal' }) }}
                        {{ form_errors(comment_form.type) }}
                        {{ form_widget(comment_form.submit) }}
                    </div>
                    {{ form_end(comment_form) }}
                </div>
            </div>

            <div class="col-lg-4">
                {{ form_start(update_ticket_form) }}
                {{ form_errors(update_ticket_form) }}
                <p class="fw-bold mb-3 text-dark fs-5">Ticket Settings</p>

                <div class="mb-3">
                    <label for="detail-status-select" class="form-label text-muted small fw-semibold">Status</label>
                    {{ form_widget(update_ticket_form.status, { id: 'detail-status-select' }) }}
                    {{ form_errors(update_ticket_form.status) }}
                </div>

                <div class="mb-3">
                    <label for="detail-priority-select" class="form-label text-muted small fw-semibold">Priority</label>
                    {{ form_widget(update_ticket_form.priority, { id: 'detail-priority-select' }) }}
                    {{ form_errors(update_ticket_form.priority) }}
                </div>

                <div class="mb-3">
                    <label for="detail-agent-select" class="form-label text-muted small fw-semibold">Assign
                        Agent</label>
                    {{ form_widget(update_ticket_form.assigned_agent, { id: 'detail-agent-select' }) }}
                    {{ form_errors(update_ticket_form.assigned_agent) }}
                </div>
                {{ form_end(update_ticket_form) }}
            </div>

            <div class="card border border-light-subtle rounded-3 p-4 bg-white shadow-sm">
                <h5 class="fw-bold mb-3 text-dark">Ticket Metadata</h5>

                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Client Name</span>
                    <span class="fw-semibold small" id="detail-client-name">Aura Cosmetics</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Category</span>
                    <span class="fw-semibold small" id="detail-category">Bug</span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Created</span>
                    <span class="fw-semibold small" id="detail-created-at">2 hours ago</span>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
