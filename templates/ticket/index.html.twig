{% extends 'dashboard/base.html.twig' %}

{% block page_title %}Tickets Queue{% endblock %}

{% block javascripts %}
    {{ importmap('dashboard.tickets') }}
    {% if not create_ticket_form.vars.valid %}
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const modalEl = document.getElementById('newTicketModal');
                if (modalEl) {
                    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                    modal.show();
                }
            });
        </script>
    {% endif %}
{% endblock %}

{% block dashboard_content %}
    <div id="view-tickets" class="view-content active-view">
        <div
            class="alert alert-light border border-light-subtle rounded-3 d-flex align-items-center mb-3 shadow-sm py-2">
            <i class="bi bi-calendar-event text-primary me-2 fs-5"></i>
            <span class="text-muted small">
                Metrics display shown below represents ticket activities for the current day: <strong class="text-dark" id="today-date-str">
                    {{- 'now'|date('d M, Y') -}}
                </strong>.
            </span>
        </div>

        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="dashboard-card d-flex align-items-center">
                    <div class="card-icon bg-light text-secondary me-3">
                        <i class="bi bi-ticket"></i>
                    </div>
                    <div>
                        <div class="text-muted card-label text-uppercase">Total Tickets</div>
                        <h3 class="fw-bold mb-0 mt-1" id="stat-total">{{ tickets_data.total }}</h3>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="dashboard-card d-flex align-items-center">
                    <div class="card-icon bg-danger-subtle text-danger me-3">
                        <i class="bi bi-envelope-open"></i>
                    </div>
                    <div>
                        <div class="text-muted card-label text-uppercase">Open / Active</div>
                        <h3 class="fw-bold mb-0 mt-1" id="stat-open">{{ tickets_data.open }}</h3>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="dashboard-card d-flex align-items-center">
                    <div class="card-icon bg-warning-subtle text-warning me-3">
                        <i class="bi bi-hourglass-split"></i>
                    </div>
                    <div>
                        <div class="text-muted card-label text-uppercase">Waiting on client</div>
                        <h3 class="fw-bold mb-0 mt-1" id="stat-pending">{{ tickets_data.pending }}</h3>
                    </div>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="dashboard-card d-flex align-items-center">
                    <div class="card-icon bg-success-subtle text-success me-3">
                        <i class="bi bi-check-circle"></i>
                    </div>
                    <div>
                        <div class="text-muted card-label text-uppercase">Resolved</div>
                        <h3 class="fw-bold mb-0 mt-1" id="stat-resolved">{{ tickets_data.resolved }}</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Filters & Action Bar -->
        <div class="card border border-light-subtle rounded-3 p-3 mb-4 bg-white shadow-sm">
            <div class="row g-3 align-items-center">
                <!-- Search bar -->
                <div class="col-12 col-md-4">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-muted"><i
                                class="bi bi-search"></i></span>
                        <input type="text" id="search-input" class="form-control bg-light border-start-0"
                               placeholder="Search tickets..." onkeyup="applyFilters()">
                    </div>
                </div>

                <!-- Filter Client -->
                <div class="col-6 col-md-2">
                    <select id="filter-client" class="form-select bg-light border-light-subtle"
                            onchange="applyFilters()">
                        <option value="">All Clients</option>
                        <option value="Aura Cosmetics">Aura Cosmetics</option>
                        <option value="Vertex SaaS">Vertex SaaS</option>
                        <option value="Greenfield Real Estate">Greenfield Real Estate</option>
                    </select>
                </div>

                {# Filter Status #}
                <div class="col-6 col-md-2">
                    <select id="filter-status" class="form-select bg-light border-light-subtle"
                            onchange="applyFilters()">
                        <option value="">All Statuses</option>
                        {% for status in enum_cases('App\\Enum\\TicketStatusEnum') %}
                            <option
                                value="{{ status.value }}"
                            >{{ status.label() }}</option>
                        {% endfor %}
                    </select>
                </div>

                <!-- Filter Priority -->
                <div class="col-6 col-md-2">
                    <select id="filter-priority" class="form-select bg-light border-light-subtle"
                            onchange="applyFilters()">
                        <option value="">All Priorities</option>
                        <option value="Critical">Critical</option>
                        <option value="High">High</option>
                        <option value="Medium">Medium</option>
                        <option value="Low">Low</option>
                    </select>
                </div>

                <!-- Add Ticket Trigger -->
                <div class="col-6 col-md-2 text-md-end">
                    <button class="btn btn-primary w-100" data-bs-toggle="modal" data-bs-target="#newTicketModal">
                        <i class="bi bi-plus-lg me-1"></i> New Ticket
                    </button>
                </div>
            </div>
        </div>

        <!-- Tickets Table Container -->
        <div class="table-container">
            <div class="table-responsive">
                <table class="table mb-0">
                    <thead>
                    <tr>
                        <th style="width: 10%">ID</th>
                        <th style="width: 35%">Subject</th>
                        <th style="width: 15%">Client</th>
                        <th style="width: 12%">Status</th>
                        <th style="width: 12%">Priority</th>
                        <th style="width: 16%">Assigned To</th>
                    </tr>
                    </thead>
                    <tbody id="tickets-table-body">
                    <!-- Dynamic Content injected via JS -->
                    </tbody>
                </table>
            </div>
            <!-- Empty State -->
            <div id="empty-state" class="text-center py-5 d-none">
                <i class="bi bi-ticket-detailed fs-1 text-muted opacity-50 mb-3 d-block"></i>
                <h5 class="fw-semibold">No tickets found</h5>
                <p class="text-muted">Try adjusting your filters or search keywords.</p>
            </div>
        </div>
    </div>

    {# Create ticket modal #}
    <div class="modal fade" id="newTicketModal" tabindex="-1" aria-labelledby="newTicketModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="newTicketModalLabel">Submit Support Ticket</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                {{ form_start(create_ticket_form) }}
                    {{ form_errors(create_ticket_form) }}
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="new-title" class="form-label fw-semibold">Subject / Issue Title</label>
                            {{ form_widget(create_ticket_form.title, { id: 'new-title' }) }}
                            {{ form_errors(create_ticket_form.title) }}
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="new-client" class="form-label fw-semibold">Client Site</label>
                                {{ form_widget(create_ticket_form.client, { id: 'new-client' }) }}
                                {{ form_errors(create_ticket_form.client) }}
                            </div>
                            <div class="col-md-6">
                                <label for="new-category" class="form-label fw-semibold">Category</label>
                                {{ form_widget(create_ticket_form.category, { id: 'new-category' }) }}
                                {{ form_errors(create_ticket_form.category) }}
                            </div>
                        </div>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label for="new-priority" class="form-label fw-semibold">Priority</label>
                                {{ form_widget(create_ticket_form.priority, { id: 'new-priority' }) }}
                                {{ form_errors(create_ticket_form.priority) }}
                            </div>
                            <div class="col-md-6">
                                <label for="new-assignee" class="form-label fw-semibold">Assign Agent</label>
                                {{ form_widget(create_ticket_form.assigned_agent, { id: 'new-assignee' }) }}
                                {{ form_errors(create_ticket_form.assigned_agent) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="new-description" class="form-label fw-semibold">Description / Error Details</label>
                            {{ form_widget(create_ticket_form.description, { id: 'new-description' }) }}
                            {{ form_errors(create_ticket_form.description) }}
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
                        {{ form_widget(create_ticket_form.submit) }}
                    </div>
                {{ form_end(create_ticket_form) }}
            </div>
        </div>
    </div>
{% endblock %}
